# ---- Backend (server/) ----
# Port for the prototype API (default 3001)
PORT=3001
# Secret for the /admin approval queue. REQUIRED in production.
ADMIN_KEY=change-me
# SQLite file location (default server/relif.db)
RELIF_DB_PATH=server/relif.db

# ---- Frontend (Vite) ----
# Where the http adapter points. Default '/api' (dev proxy → localhost:3001).
# Swap the backend by changing this URL — no code changes needed.
VITE_API_BASE_URL=/api
# 'http' (default, falls back to bundled data if unreachable) or 'bundled'
# for a fully static build with no backend at all.
VITE_DATA_SOURCE=http
