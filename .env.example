# PostHog analytics — copy to `.env.local` and fill in your project values.
# Analytics stays disabled (no network calls) until VITE_POSTHOG_KEY is set.

# Project API key from PostHog → Settings → Project (starts with phc_)
VITE_POSTHOG_KEY=

# Ingestion host. US cloud is the default; use https://eu.i.posthog.com for EU,
# or your self-hosted URL. Leave unset to use the US default.
VITE_POSTHOG_HOST=https://us.i.posthog.com
